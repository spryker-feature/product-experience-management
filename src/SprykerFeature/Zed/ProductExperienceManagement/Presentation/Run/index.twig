{% extends '@Gui/Layout/layout.twig' %}

{% set widget_title = 'Import Runs' | trans %}

{% block head_title widget_title %}
{% block section_title widget_title %}

{% block action %}
    {{ backActionButton(url('/product-experience-management/job/index'), 'Back to Jobs' | trans) }}
    {{ createActionButton(url('/product-experience-management/run/create', {importJobReference: importJobReference}), 'Create Run' | trans) }}
{% endblock %}

{% block content %}
    {% embed '@Gui/Partials/widget.twig' with { widget_title: widget_title } %}
        {% block widget_content %}
            {{ table | raw }}
        {% endblock %}
    {% endembed %}
{% endblock %}
