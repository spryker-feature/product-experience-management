{% if errors | length > 0 %}
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Row #</th>
                <th>Error Message</th>
            </tr>
        </thead>
        <tbody>
            {% for error in errors %}
                <tr>
                    <td>{{ error.csvRowNumber ?: '-' }}</td>
                    <td>{{ error.errorMessage }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% else %}
    <p class="text-success">No errors found for this run.</p>
{% endif %}
