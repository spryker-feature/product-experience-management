{% extends '@Gui/Layout/layout.twig' %}

{% set widget_title = 'Export Products' | trans %}

{% block head_title widget_title %}
{% block section_title widget_title %}

{% block action %}
    {{ backActionButton(url('/product-experience-management/job'), 'Back to Jobs' | trans) }}
{% endblock %}

{% block content %}
    {% embed '@Gui/Partials/widget.twig' with { widget_title: 'Export Products' | trans } %}
        {% block widget_content %}
            <div class="row form-group">
                <div class="col-sm-12">
                    {{ 'Select a job and click Export to download all products as CSV.' | trans }}
                </div>
            </div>
            {% if importJobs is empty %}
                <div class="row form-group">
                    <div class="col-sm-12">
                        <div class="alert alert-warning">
                            {{ 'No import jobs found. Please create a job first to have an export definition.' | trans }}
                            <a href="{{ url('/product-experience-management/job/create') }}" class="alert-link">{{ 'Create a job' | trans }}</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="row form-group">
                    <label class="col-sm-2 control-label">{{ 'Job' | trans }} *</label>
                    <div class="col-sm-4">
                        <select id="exportJobReference" class="form-control">
                            {% for importJob in importJobs %}
                                <option value="{{ importJob.reference }}">{{ importJob.name }} ({{ importJob.type }})</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-sm-offset-2 col-sm-10">
                        <a id="exportButton" href="#" class="btn btn-primary">
                            <i class="fa fa-download"></i> {{ 'Export' | trans }}
                        </a>
                    </div>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}

    <script src="{{ assetsPath('js/spryker-zed-product-experience-management-export.js') }}"></script>
{% endblock %}
